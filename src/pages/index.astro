---
import LandingLayout from "../layouts/LandingLayout.astro";
import ThemeSwitch from "../components/ThemeSwitch.astro";
import LandingHero from "../components/landing/LandingHero.astro";
import LandingProblem from "../components/landing/LandingProblem.astro";
import LandingShift from "../components/landing/LandingShift.astro";
import LandingWho from "../components/landing/LandingWho.astro";
import LandingServices from "../components/landing/LandingServices.astro";
import LandingCounterStrip from "../components/landing/LandingCounterStrip.astro";
import LandingDifferentiation from "../components/landing/LandingDifferentiation.astro";
import LandingProcess from "../components/landing/LandingProcess.astro";
import LandingProof from "../components/landing/LandingProof.astro";
import LandingFaq from "../components/landing/LandingFaq.astro";
import LandingFinalCta from "../components/landing/LandingFinalCta.astro";
import { site } from "../content/home";
import { landing } from "../content/landing";
import "../styles/landing.css";

const fc = landing.footer;
---

<!--
  LandingLayout renders content directly inside <body class="is-landing">.
  There is NO <main> element with a max-width constraint.
  Every section is a full-width direct child of <body>.
-->
<LandingLayout title="Home" description={landing.metaDescription}>

  <!-- ── Fixed nav ── -->
  <nav class="lp-nav" id="lp-nav" aria-label="Primary">
    <div class="lp-nav-inner">
      <a class="lp-logo" href="/">{site.logoInitials}</a>
      <ul class="lp-nav-links">
        <li><a href="#approach">Approach</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#process">Process</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="/contact" class="btn btn--outline">Book a Strategy Call</a></li>
      </ul>
      <div class="lp-nav-right">
        <ThemeSwitch />
      </div>
    </div>
  </nav>

  <!-- ── Page content (landmark for a11y) ── -->
  <div id="lp-content" role="main">
    <LandingHero />
    <LandingProblem />
    <LandingShift />
    <LandingWho />
    <LandingServices />
    <LandingCounterStrip />
    <LandingDifferentiation />
    <LandingProcess />
    <LandingProof />
    <LandingFaq />
    <LandingFinalCta />
  </div>

  <!-- ── Footer ── -->
  <footer class="lp-footer">
    <div class="lp-footer-inner">
      <a class="lp-footer-logo" href="/">{site.logoInitials}</a>
      <div class="lp-footer-contact">
        <a href={`mailto:${fc.email}`}>{fc.email}</a>
        <span aria-hidden="true">·</span>
        <a href={`tel:${fc.phoneTel}`}>{fc.phoneDisplay}</a>
        <span aria-hidden="true">·</span>
        <span>Dubai, UAE</span>
      </div>
      <nav class="lp-footer-legal" aria-label="Legal">
        <a href="/legal/privacy">Privacy Policy</a>
        <a href="/legal/imprint">Imprint</a>
      </nav>
    </div>
  </footer>

  <!-- ── Scripts ── -->
  <script is:inline>
  (function () {
    /* ─── Scroll-reveal (rv elements) ─── */
    var revEls = document.querySelectorAll(".rv");
    if ("IntersectionObserver" in window) {
      var rvIO = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              rvIO.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -4% 0px" }
      );
      revEls.forEach(function (el) { rvIO.observe(el); });
    } else {
      revEls.forEach(function (el) { el.classList.add("in"); });
    }

    /* ─── Nav glass-on-scroll ─── */
    var nav = document.getElementById("lp-nav");
    if (nav) {
      var navSolid = false;
      function checkNav() {
        var s = window.scrollY > 60;
        if (s !== navSolid) {
          navSolid = s;
          nav.classList.toggle("lp-nav--solid", s);
        }
      }
      window.addEventListener("scroll", checkNav, { passive: true });
      checkNav();
    }

    /* ─── Counter strip ─── */
    var strip = document.querySelector("[data-stat-strip]");
    if (strip && "IntersectionObserver" in window) {
      var counted = false;
      var cIO = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting && !counted) {
            counted = true;
            cIO.disconnect();
            strip.querySelectorAll("[data-count]").forEach(function (el) {
              var target = parseInt(el.getAttribute("data-count"), 10);
              var suffix = el.getAttribute("data-suffix") || "";
              var dur = 1800;
              var start = performance.now();
              (function tick(now) {
                var p = Math.min((now - start) / dur, 1);
                var eased = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.round(target * eased) + suffix;
                if (p < 1) requestAnimationFrame(tick);
              })(start);
            });
          }
        },
        { threshold: 0.4 }
      );
      cIO.observe(strip);
    }

    /* ─── Process card grid ─── */
    var procWrap = document.querySelector("[data-process-wrap]");
    if (procWrap && "IntersectionObserver" in window) {
      var procIO = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting) {
            procIO.disconnect();
            procWrap.querySelectorAll("[data-ps]").forEach(function (el, i) {
              setTimeout(function () { el.classList.add("in"); }, i * 120);
            });
          }
        },
        { threshold: 0.1 }
      );
      procIO.observe(procWrap);
    }

    /* ─── Problem stats in-view trigger ─── */
    var statsCols = document.querySelectorAll("[data-anim-stats]");
    if ("IntersectionObserver" in window) {
      var statIO = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("in-view");
              statIO.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      statsCols.forEach(function (el) { statIO.observe(el); });
    }
  })();
  </script>
</BaseLayout>
