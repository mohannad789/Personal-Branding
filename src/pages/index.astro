---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingHero from "../components/landing/LandingHero.astro";
import LandingMirror from "../components/landing/LandingMirror.astro";
import LandingIndictment from "../components/landing/LandingIndictment.astro";
import LandingOffer from "../components/landing/LandingOffer.astro";
import LandingAvatars from "../components/landing/LandingAvatars.astro";
import LandingProof from "../components/landing/LandingProof.astro";
import LandingAbout from "../components/landing/LandingAbout.astro";
import LandingClose from "../components/landing/LandingClose.astro";
import { landing } from "../content/landing";
import "../styles/landing.css";

const title = "Home";
---

<BaseLayout
  title={title}
  description={landing.metaDescription}
  navMode="landing"
  ctaHref="/contact"
  ctaLabel="Let's talk"
  mainClass="main--landing"
>
  <LandingHero />
  <LandingMirror />
  <LandingIndictment />
  <LandingOffer />
  <LandingAvatars />
  <LandingProof />
  <LandingAbout />
  <LandingClose />
</BaseLayout>
