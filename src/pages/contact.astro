---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../content/home";
---

<BaseLayout title="Contact" description={`Contact ${site.name}.`} mainClass="main--narrow">
  <section class="placeholder-page" aria-labelledby="contact-heading">
    <h1 id="contact-heading">Contact</h1>
    <p class="lede">
      A dedicated contact form and routing will be added later. For now, use the links on the
      <a href="/#contact">home page</a>.
    </p>
    <p class="prose">
      <a class="card-link" href="/">← Back to home</a>
    </p>
  </section>
</BaseLayout>
