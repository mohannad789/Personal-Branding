---
import { site } from "../content/home";
import { landing } from "../content/landing";
const fc = landing.footer;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Strategic Personal Branding — Version B</title>
  <meta name="description" content="Strategic personal branding for entrepreneurs who've outgrown word of mouth." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:     #0C0F14;
      --bg2:    #12151B;
      --bg3:    #1A1D24;
      --text:   #F7F5F2;
      --muted:  #8A8A8A;
      --accent: #4F8FF7;
      --accent-dim: #3B7AE0;
      --steel:  #4A6FA5;
      --fh:     "Fraunces", Georgia, serif;
      --fb:     "Inter", system-ui, sans-serif;
      --pad:    clamp(1.5rem, 4vw, 2.5rem);
      --sec:    clamp(2.5rem, 5vw, 3.5rem);
      --max:    720px;
      --max-wide: 900px;
    }

    html { overflow-x: hidden; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--fb);
      font-size: 1rem;
      line-height: 1.65;
      padding-top: 4.25rem;
    }

    #v2-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem var(--pad);
      background: color-mix(in srgb, var(--bg) 92%, transparent);
      border-bottom: 1px solid rgba(79, 143, 247, 0.12);
    }
    .v2-logo { font-family: var(--fh); font-size: 1.0625rem; font-weight: 600; color: var(--text); text-decoration: none; }
    .v2-nav-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .v2-ver-link {
      font-size: 0.8125rem; color: var(--muted); text-decoration: none;
      border: 1px solid rgba(255,255,255,0.12); border-radius: 999px; padding: 0.4rem 1rem;
    }
    .v2-ver-link:hover { color: var(--text); border-color: rgba(79,143,247,0.35); }
    .v2-cta {
      font-size: 0.875rem; font-weight: 600; color: var(--accent);
      border: 1px solid rgba(79,143,247,0.45); border-radius: 999px; padding: 0.5rem 1.25rem; text-decoration: none;
    }
    .v2-cta:hover { background: rgba(79,143,247,0.15); }

    .v2-wrap { max-width: var(--max-wide); margin: 0 auto; padding: 0 var(--pad); }

    section {
      padding-block: var(--sec);
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    section:first-of-type { border-top: none; }

    .v2-center { text-align: center; }
    .v2-eyebrow {
      font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1rem; display: block;
    }
    .v2-h1 {
      font-family: var(--fh); font-weight: 700; font-size: clamp(2rem, 5vw, 3.25rem);
      line-height: 1.12; letter-spacing: -0.03em; margin-bottom: 1rem;
    }
    .v2-h2 {
      font-family: var(--fh); font-weight: 700; font-size: clamp(1.5rem, 3.5vw, 2.25rem);
      line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 1rem;
    }
    .v2-h3 { font-family: var(--fh); font-weight: 600; font-size: 1.25rem; margin-bottom: 0.5rem; }
    .v2-p { color: var(--muted); margin-bottom: 1rem; max-width: var(--max); margin-inline: auto; }
    .v2-p:last-child { margin-bottom: 0; }
    .v2-p--wide { max-width: none; }
    .v2-accent { color: var(--accent); font-weight: 600; }

    .v2-stats {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;
      margin-top: 1.5rem; text-align: center;
    }
    @media (min-width: 640px) { .v2-stats { grid-template-columns: repeat(4, 1fr); } }
    .v2-stat-num { font-family: var(--fh); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: var(--accent); display: block; margin-bottom: 0.35rem; }
    .v2-stat-label { font-size: 0.8125rem; color: var(--muted); line-height: 1.45; }

    .v2-badge { font-size: 0.625rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-top: 1.5rem; text-align: left; }

    .v2-chat { max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem; }
    .v2-bubble-r, .v2-bubble-l {
      padding: 0.875rem 1.125rem; border-radius: 14px; font-size: 0.9375rem; line-height: 1.55;
    }
    .v2-bubble-r { align-self: flex-end; background: #2C2C2E; max-width: 90%; }
    .v2-bubble-l { align-self: flex-start; background: var(--bg3); max-width: 90%; }

    .v2-pair { margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.06); text-align: center; }
    .v2-pair:last-of-type { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .v2-wrong { font-family: var(--fh); font-size: 1.0625rem; color: var(--muted); text-decoration: line-through; margin-bottom: 0.5rem; }
    .v2-right { font-family: var(--fh); font-size: 1.125rem; color: var(--accent); font-weight: 600; margin-bottom: 0.5rem; }
    .v2-pair-note { font-size: 0.9375rem; color: var(--muted); max-width: 42ch; margin-inline: auto; }

    .v2-split { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; text-align: left; margin-top: 1.5rem; }
    @media (max-width: 700px) { .v2-split { grid-template-columns: 1fr; } }
    .v2-split h3 { font-size: 0.6875rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1rem; font-family: var(--fb); font-weight: 600; }
    .v2-split ul { list-style: none; }
    .v2-split li { font-size: 0.9375rem; margin-bottom: 0.65rem; color: var(--muted); display: flex; gap: 0.5rem; align-items: flex-start; }
    .v2-split .v2-yes { color: var(--text); }
    .v2-split .v2-yes .v2-li-mark { color: var(--accent); flex-shrink: 0; }

    .v2-card {
      background: var(--bg2); border: 1px solid rgba(79,143,247,0.15); border-radius: 12px;
      padding: 1.5rem; margin-bottom: 1rem; text-align: left;
    }
    .v2-card-num { font-size: 0.625rem; font-weight: 700; letter-spacing: 0.15em; color: var(--accent); margin-bottom: 0.5rem; }

    .v2-manifesto { font-family: var(--fh); font-size: clamp(1.25rem, 3vw, 1.75rem); line-height: 1.45; text-align: center; max-width: 28ch; margin-inline: auto; }
    .v2-manifesto p { margin-bottom: 0.75rem; color: var(--text); }
    .v2-manifesto .v2-m-accent { color: var(--accent); font-weight: 600; }

    .v2-counters { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; text-align: center; }
    @media (min-width: 768px) { .v2-counters { grid-template-columns: repeat(4, 1fr); } }
    .v2-cnum { font-family: var(--fh); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--accent); display: block; }
    .v2-clabel { font-size: 0.8125rem; color: var(--muted); }

    .v2-funnel .v2-bar-row { margin-bottom: 1rem; text-align: center; }
    .v2-track { background: rgba(255,255,255,0.06); border-radius: 6px; height: 52px; margin: 0 auto; overflow: hidden; }
    .v2-r1 .v2-track { width: 100%; max-width: 100%; }
    .v2-r2 .v2-track { width: 70%; max-width: 420px; }
    .v2-r3 .v2-track { width: 42%; max-width: 260px; }
    .v2-fill { height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--fh); font-weight: 700; font-size: 1.0625rem; color: #0C0F14; }
    .v2-fill-blue { background: linear-gradient(90deg, var(--accent), var(--accent-dim)); width: 70%; }
    .v2-fill-steel { background: var(--steel); width: 80%; }
    .v2-fill-full { background: linear-gradient(90deg, var(--accent), #6FA5FF); width: 100%; }
    .v2-bar-cap { font-size: 0.8125rem; color: var(--muted); margin-top: 0.35rem; }

    .v2-btn {
      display: inline-block; margin-top: 1.25rem; padding: 0.875rem 2rem;
      font-weight: 600; font-size: 0.9375rem; text-decoration: none; border-radius: 999px;
      background: var(--accent); color: #fff;
    }
    .v2-btn:hover { filter: brightness(1.08); }

    #s19 {
      background: #06080C; padding: 2rem var(--pad);
      display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .s19-logo { font-family: var(--fh); font-size: 1rem; font-weight: 600; color: rgba(247,245,242,0.35); text-decoration: none; }
    .s19-contact, .s19-legal { display: flex; flex-wrap: wrap; gap: 1rem; }
    .s19-contact a, .s19-legal a { font-size: 0.8125rem; color: var(--muted); text-decoration: none; }
    .s19-contact a:hover, .s19-legal a:hover { color: var(--accent); }
  </style>
</head>
<body>

<nav id="v2-nav">
  <a href="/" class="v2-logo">{site.logoInitials}</a>
  <div class="v2-nav-right">
    <a href="/" class="v2-ver-link">← Version A</a>
    <a href="/contact" class="v2-cta">Book a Strategy Call</a>
  </div>
</nav>

<main class="v2-wrap">

  <!-- Proof stats -->
  <section class="v2-center">
    <div class="v2-stats">
      <div><span class="v2-stat-num">82%</span><span class="v2-stat-label">of B2B buyers trust founder-led brands over corporate ones</span></div>
      <div><span class="v2-stat-num">70%</span><span class="v2-stat-label">of the purchase decision is made before first contact</span></div>
      <div><span class="v2-stat-num">3.2×</span><span class="v2-stat-label">higher engagement on founder content vs. brand content</span></div>
      <div><span class="v2-stat-num">€M+</span><span class="v2-stat-label">inbound pipeline generated for clients in DACH and the Gulf</span></div>
    </div>
    <p class="v2-badge">Strategic Personal Branding | Dubai</p>
  </section>

  <section class="v2-center">
    <p class="v2-eyebrow" style="margin-bottom:0">For Entrepreneurs and Founders in DACH and the Gulf</p>
    <p class="v2-p v2-p--wide" style="color:var(--accent);font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem">
      who've outgrown word of mouth
    </p>
  </section>

  <section class="v2-center">
    <h1 class="v2-h1">
      We build personal brand positions that generate <span class="v2-accent">revenue.</span>
    </h1>
    <p class="v2-p">Not followers. Not impressions. Not visibility for its own sake. Revenue.</p>
    <a href="/contact" class="v2-btn">Book a Strategy Call</a>
    <p class="v2-p" style="margin-top:1rem;font-size:0.8125rem">Now accepting Q3 engagements.</p>
  </section>

  <section class="v2-center">
    <span class="v2-eyebrow">The Invisible Authority Trap</span>
    <h2 class="v2-h2">You've built a business that proves you're exceptional.</h2>
    <h2 class="v2-h2 v2-accent">Your market hasn't noticed yet.</h2>
    <p class="v2-p">Your track record should be doing the selling. Instead, you're still the one doing the explaining.</p>
  </section>

  <section>
    <p class="v2-eyebrow v2-center">Your current reality</p>
    <div class="v2-card">
      <p class="v2-p v2-p--wide" style="font-style:italic;color:var(--text)">"Every major client I have came through a personal introduction."</p>
      <p class="v2-p v2-p--wide">That's not a business model. That's a dependency with a ceiling the exact size of your personal network.</p>
    </div>
    <div class="v2-card">
      <p class="v2-p v2-p--wide" style="font-style:italic;color:var(--text)">"I post content regularly. The leads are lukewarm and the brand sounds like everyone else's."</p>
      <p class="v2-p v2-p--wide">Activity without architecture. You're feeding the algorithm. The algorithm is not feeding you back.</p>
    </div>
    <div class="v2-card">
      <p class="v2-p v2-p--wide" style="font-style:italic;color:var(--text)">"I keep losing deals to founders with half my track record but twice my visibility."</p>
      <p class="v2-p v2-p--wide">The market doesn't reward the most qualified. It rewards the most legible. Right now, you're illegible.</p>
    </div>
    <div class="v2-card">
      <p class="v2-p v2-p--wide" style="font-style:italic;color:var(--text)">"People who work with me are blown away. People who haven't don't know I exist."</p>
      <p class="v2-p v2-p--wide">Your reputation is locked behind a door that only opens from the inside.</p>
    </div>
  </section>

  <section class="v2-center">
    <h2 class="v2-h2">You don't have a marketing problem.</h2>
    <h2 class="v2-h2">You have a positioning problem.</h2>
    <h2 class="v2-h2 v2-accent" style="margin-top:0.5rem">And it's costing you more than you think.</h2>
  </section>

  <section style="background:var(--bg2)">
    <div class="v2-chat">
      <div class="v2-bubble-r">"Sounds compelling. But I've heard this before. The last agency gave me a content calendar and called it strategy."</div>
      <div class="v2-bubble-l">"We know. And we know why."</div>
    </div>
  </section>

  <section class="v2-center">
    <p class="v2-p v2-p--wide">Most agencies sell activity because activity is easy to deliver and easy to report on.</p>
    <p class="v2-p v2-p--wide">"We posted 12 times this week" is a metric that sounds productive. It is also completely disconnected from revenue.</p>
    <p class="v2-p v2-p--wide" style="margin-top:1.5rem">Here's the question they never asked you:</p>
    <h2 class="v2-h2 v2-accent" style="max-width:22ch;margin-inline:auto;margin-top:0.5rem">
      What specific perception does your market need to hold about you for revenue to follow?
    </h2>
    <p class="v2-p v2-p--wide" style="margin-top:1.5rem">Not "what should we post." Not "which platforms."</p>
    <p class="v2-p v2-p--wide">That's where we start. Everything else is built to serve that answer.</p>
    <a href="/contact" class="v2-btn">Book a Strategy Call</a>
  </section>

  <section>
    <div class="v2-center" style="margin-bottom:2rem">
      <span class="v2-eyebrow">The position-first method</span>
      <h2 class="v2-h2">Why most personal brands fail before they start.</h2>
    </div>
    <div class="v2-pair">
      <p class="v2-wrong">Start by creating content.</p>
      <p class="v2-right">Start by defining the perception that drives revenue.</p>
      <p class="v2-pair-note">The blueprint. Without it, everything else is decoration.</p>
    </div>
    <div class="v2-pair">
      <p class="v2-wrong">Build a presence on every platform.</p>
      <p class="v2-right">Build authority in the rooms that matter.</p>
      <p class="v2-pair-note">Your ideal client isn't everywhere. They're in specific rooms. We engineer your entry.</p>
    </div>
    <div class="v2-pair">
      <p class="v2-wrong">Post consistently and hope for compounding.</p>
      <p class="v2-right">Architect a system where every asset serves the position.</p>
      <p class="v2-pair-note">Nothing is filler. Nothing is "keeping the feed alive." Each asset is a brick in a structure.</p>
    </div>
    <div class="v2-pair">
      <p class="v2-wrong">Measure followers, impressions, and engagement.</p>
      <p class="v2-right">Measure inbound leads, deal velocity, and pipeline source.</p>
      <p class="v2-pair-note">If it doesn't move revenue, it doesn't survive the next quarter.</p>
    </div>
  </section>

  <section style="background:var(--bg2)">
    <div class="v2-chat">
      <div class="v2-bubble-r">"Personal branding still sounds like self-promotion. The work should speak for itself."</div>
      <div class="v2-bubble-l">"It should. And in a perfect market, it would."</div>
    </div>
  </section>

  <section>
    <div class="v2-split">
      <div>
        <h3 class="v2-accent">Who we work with</h3>
        <ul>
          <li class="v2-yes"><span class="v2-li-mark">→</span><span>Founders and entrepreneurs, 40+, revenue €1M+</span></li>
          <li class="v2-yes"><span class="v2-li-mark">→</span><span>Established in their field, invisible outside their network</span></li>
          <li class="v2-yes"><span class="v2-li-mark">→</span><span>Based in DACH or the Gulf</span></li>
          <li class="v2-yes"><span class="v2-li-mark">→</span><span>Tired of agencies that delivered activity, not outcomes</span></li>
          <li class="v2-yes"><span class="v2-li-mark">→</span><span>Ready to invest at the level the outcome requires</span></li>
        </ul>
      </div>
      <div>
        <h3 style="color:var(--muted)">Who we don't</h3>
        <ul>
          <li><span class="v2-li-mark">×</span><span>Looking for a social media manager with a strategy title</span></li>
          <li><span class="v2-li-mark">×</span><span>Measuring success in followers and likes</span></li>
          <li><span class="v2-li-mark">×</span><span>Wanting to "go viral"</span></li>
          <li><span class="v2-li-mark">×</span><span>Businesses without a proven offer</span></li>
        </ul>
      </div>
    </div>
    <p class="v2-center v2-accent" style="font-family:var(--fh);font-style:italic;font-size:1.125rem;margin-top:2rem">
      Virality is a lottery ticket. Positioning is a pension.
    </p>
  </section>

  <section>
    <div class="v2-center" style="margin-bottom:1.5rem">
      <span class="v2-eyebrow">What we build</span>
      <h2 class="v2-h2">The architecture behind authority.</h2>
    </div>
    <div class="v2-card"><p class="v2-card-num">01</p><h3 class="v2-h3">Commercial positioning</h3><p class="v2-p v2-p--wide" style="margin:0;color:var(--muted)">We define how your market should perceive you — and for what commercial purpose. Not a brand deck. A revenue strategy with your name on it.</p></div>
    <div class="v2-card"><p class="v2-card-num">02</p><h3 class="v2-h3">Narrative architecture</h3><p class="v2-p v2-p--wide" style="margin:0;color:var(--muted)">The story the market tells about you. We make sure it's the right one. Sharp frameworks, thought leadership angles, and a point of view worth having.</p></div>
    <div class="v2-card"><p class="v2-card-num">03</p><h3 class="v2-h3">Strategic visibility</h3><p class="v2-p v2-p--wide" style="margin:0;color:var(--muted)">The right content, aimed at the right rooms. Every asset earns its place. Nothing ships that doesn't serve the position.</p></div>
    <div class="v2-card"><p class="v2-card-num">04</p><h3 class="v2-h3">Revenue infrastructure</h3><p class="v2-p v2-p--wide" style="margin:0;color:var(--muted)">The bridge between "I've heard your name" and "I want to hire you." The invisible machinery that turns recognition into business.</p></div>
  </section>

  <section class="v2-center" style="background:#080A0F">
    <div class="v2-manifesto">
      <p>The market is not rational.</p>
      <p>It is perceptual.</p>
      <p>People don't choose the most qualified expert.</p>
      <p>They choose the one they already trust.</p>
      <p>Trust is not earned in the meeting.</p>
      <p>It is engineered before the meeting ever happens.</p>
      <p class="v2-m-accent">That's what we build.</p>
    </div>
  </section>

  <section>
    <div class="v2-counters">
      <div><span class="v2-cnum">8+</span><span class="v2-clabel">Years of strategic advisory</span></div>
      <div><span class="v2-cnum">12</span><span class="v2-clabel">Markets across DACH &amp; Gulf</span></div>
      <div><span class="v2-cnum">94%</span><span class="v2-clabel">Client retention</span></div>
      <div><span class="v2-cnum">3×</span><span class="v2-clabel">Average inbound increase in 12 months</span></div>
    </div>
  </section>

  <section style="background:var(--bg2)">
    <div class="v2-chat">
      <div class="v2-bubble-r">"How do I know this actually delivers ROI?"</div>
      <div class="v2-bubble-l">"Because we only measure what you'd measure."</div>
    </div>
  </section>

  <section>
    <div class="v2-center" style="margin-bottom:1.5rem">
      <span class="v2-eyebrow">Client outcomes</span>
      <h2 class="v2-h2">There's a reason founders stay.</h2>
    </div>
    <div class="v2-card">
      <p class="v2-accent" style="font-family:var(--fh);font-weight:600;margin-bottom:0.75rem">Placeholder — 3.2× inbound increase</p>
      <p class="v2-p v2-p--wide" style="font-style:italic;color:var(--text)">Replace with a real testimonial focusing on a specific commercial outcome.</p>
      <p class="v2-p v2-p--wide" style="font-size:0.8125rem;margin:0">SaaS Founder, Munich</p>
    </div>
    <div class="v2-card">
      <p class="v2-accent" style="font-family:var(--fh);font-weight:600;margin-bottom:0.75rem">Placeholder — 47% shorter sales cycle</p>
      <p class="v2-p v2-p--wide" style="font-style:italic;color:var(--text)">Second testimonial: a specific deal closed or position shift within a timeframe.</p>
      <p class="v2-p v2-p--wide" style="font-size:0.8125rem;margin:0">Managing Partner, Dubai</p>
    </div>
  </section>

  <section class="v2-center v2-funnel">
    <h2 class="v2-h2">What happens before the handshake.</h2>
    <div class="v2-bar-row v2-r1">
      <div class="v2-track"><div class="v2-fill v2-fill-blue">70%</div></div>
      <p class="v2-bar-cap">of the decision is made before first contact</p>
    </div>
    <div class="v2-bar-row v2-r2">
      <div class="v2-track"><div class="v2-fill v2-fill-steel">&nbsp;</div></div>
      <p class="v2-bar-cap">Based on content, media presence, and peer perception</p>
    </div>
    <div class="v2-bar-row v2-r3">
      <div class="v2-track"><div class="v2-fill v2-fill-full">Your brand</div></div>
      <p class="v2-bar-cap v2-accent">is doing the selling</p>
    </div>
  </section>

