      box-shadow: 0 0 40px var(--gold-g);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .s18-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 48px var(--gold-g); }
    .s18-note { font-family: var(--fb); font-size: 0.8125rem; color: var(--muted); margin-top: 1.25rem; }

