  <div class="s17-inner">
    <h2 class="s17-title">What happens<br>before the handshake.</h2>
    <div class="s17-row s17-row-1"><div class="s17-track"><div class="s17-fill s17-fill-gold s17-fill-1">70%</div></div></div>
    <p class="s17-label">of the decision is made before first contact</p>
    <div style="height:1.5rem"></div>
    <div class="s17-row s17-row-2"><div class="s17-track"><div class="s17-fill s17-fill-steel s17-fill-2"></div></div></div>
    <p class="s17-label">Based on content, media presence, and peer perception</p>
    <div style="height:1.5rem"></div>
    <div class="s17-row s17-row-3"><div class="s17-track"><div class="s17-fill s17-fill-gold-strong s17-fill-3">Your brand</div></div></div>
    <p class="s17-label" style="color:var(--gold)">is doing the selling</p>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════
     SCENE 18 — Final CTA
══════════════════════════════════════════════════════════════ -->
<section id="s18" class="v2-scene">
  <div class="s18-inner">
    <div class="v2-eyebrow">For Future Market Leaders Only</div>
    <h2 class="s18-headline">Your Next Client<br>Is Forming An Opinion<br>About You<br>Right Now.</h2>
    <p class="s18-body">Not tomorrow. Now. They're Googling your name. Reading your LinkedIn. Asking a colleague what they know about you.</p>
    <span class="s18-gold">Make sure the answer<br>isn't silence.</span>
    <div>
      <a href="/contact" class="s18-btn">Book Your Strategy Call</a>
    </div>
    <p class="s18-note">Dubai-based. Serving the DACH region and the Gulf.<br>We take on a limited number of clients per quarter.</p>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════
     SCENE 19 — Footer
══════════════════════════════════════════════════════════════ -->
<footer id="s19">
  <a href="/" class="s19-logo">{site.logoInitials}</a>
  <div class="s19-contact">
    <a href={`mailto:${fc.email}`}>{fc.email}</a>
    <a href={`tel:${fc.phoneTel}`}>{fc.phoneDisplay}</a>
    <span style="color:var(--muted)">Dubai, UAE</span>
  </div>
  <nav class="s19-legal">
    <a href="/legal/privacy">Privacy Policy</a>
    <a href="/legal/imprint">Imprint</a>
  </nav>
</footer>

<!-- ══════════════════════════════════════════════════════════════
     ALL JAVASCRIPT
══════════════════════════════════════════════════════════════ -->
<script is:inline>
(function () {

  /* ── Scene 1: Auto-carousel ───────────────────────────────── */
  var slides = document.querySelectorAll('.s1-slide');
  var bar = document.getElementById('s1-bar');
  var cur = 0;
  function nextSlide() {
    slides[cur].classList.remove('active');
    cur = (cur + 1) % slides.length;
    slides[cur].classList.add('active');
    bar.style.width = '0';
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        bar.style.width = '100%';
      });
    });
  }
  bar.style.width = '100%';
  setInterval(nextSlide, 4000);

  /* ── IntersectionObserver factory ───────────────────────────── */
  function onEnter(selector, cb, options) {
    var els = typeof selector === 'string' ? document.querySelectorAll(selector) : [selector];
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { cb(e.target); io.unobserve(e.target); }
      });
    }, Object.assign({ threshold: 0.2 }, options || {}));
    els.forEach(function (el) { io.observe(el); });
  }

  /* ── Scene 2: Qualifier fade ─────────────────────────────── */
  onEnter('.s2-text', function (el) { el.classList.add('in'); });

  /* ── Scene 3: Scroll-driven words ───────────────────────────── */
  var s3 = document.getElementById('s3');
  var s3words = s3.querySelectorAll('.s3-word');
  var s3sub = document.getElementById('s3-sub');
  var s3act = document.getElementById('s3-actions');
  var TOTAL = s3words.length + 2; // words + sub + cta
  function updateS3() {
    var rect = s3.getBoundingClientRect();
    var scrollable = s3.offsetHeight - window.innerHeight;
    var pct = Math.max(0, Math.min(1, -rect.top / scrollable));
    s3words.forEach(function (w, i) {
      var t = (i + 1) / TOTAL;
      var isGold = w.classList.contains('s3-word--gold');
      if (pct >= t) {
        w.classList.add(isGold ? 'on-gold' : 'on');
      } else {
        w.classList.remove('on', 'on-gold');
      }
    });
    s3sub.classList.toggle('on', pct >= s3words.length / TOTAL);
    s3act.classList.toggle('on', pct >= (s3words.length + 1) / TOTAL);
  }
  window.addEventListener('scroll', updateS3, { passive: true });

  /* ── Scene 4: Collision ───────────────────────────────────── */
  onEnter('#s4', function (el) {
    setTimeout(function () {
      el.classList.add('collide');
      setTimeout(function () { el.classList.add('shake'); }, 120);
    }, 200);
  }, { threshold: 0.4 });

  /* ── Scene 5: Pain slides ─────────────────────────────────── */
  var s5 = document.getElementById('s5');
  var s5slides = s5.querySelectorAll('.s5-slide');
  var s5bar = document.getElementById('s5-bar');
  function updateS5() {
    var rect = s5.getBoundingClientRect();
    var scrollable = s5.offsetHeight - window.innerHeight;
    var pct = Math.max(0, Math.min(1, -rect.top / scrollable));
    var idx = Math.min(s5slides.length - 1, Math.floor(pct * s5slides.length));
    s5slides.forEach(function (sl, i) { sl.classList.toggle('active', i === idx); });
    s5bar.style.width = (((idx + 1) / s5slides.length) * 100) + '%';
  }
  window.addEventListener('scroll', updateS5, { passive: true });

  /* ── Scene 6: Diagnosis ───────────────────────────────────── */
  var s6 = document.getElementById('s6');
  var s6lines = s6.querySelectorAll('.s6-line');
  var S6TOTAL = s6lines.length;
  function updateS6() {
    var rect = s6.getBoundingClientRect();
    var scrollable = s6.offsetHeight - window.innerHeight;
    var pct = Math.max(0, Math.min(1, -rect.top / scrollable));
    s6lines.forEach(function (l, i) {
      var t = (i + 1) / S6TOTAL;
      l.classList.toggle(l.classList.contains('s6-line-gold') ? 'on' : 'on', pct >= t);
    });
  }
  window.addEventListener('scroll', updateS6, { passive: true });

  /* ── Chat bubbles ────────────────────────────────────────── */
  onEnter('[data-chat]', function (el) { el.classList.add('fired'); }, { threshold: 0.35 });

  /* ── Scene 8: Answer scroll ──────────────────────────────── */
  var s8 = document.getElementById('s8');
  if (s8) {
    var s8lines = s8.querySelectorAll('[data-s8]');
    var s8bigs = s8.querySelectorAll('[data-s8-big]');
    var s8cta = s8.querySelector('[data-s8-cta]');
    var S8TOTAL = s8lines.length + 2;
    function updateS8() {
      var rect = s8.getBoundingClientRect();
      var scrollable = s8.offsetHeight - window.innerHeight;
      var pct = Math.max(0, Math.min(1, -rect.top / scrollable));
      s8lines.forEach(function (l, i) {
        var t = (i + 1) / S8TOTAL;
        var isLate = parseInt(l.getAttribute('data-s8'), 10) >= 8;
        l.classList.toggle(isLate ? 'on-bright' : 'on', pct >= t);
      });
      s8bigs.forEach(function (b) { b.classList.toggle('on', pct >= 0.5); });
      if (s8cta) s8cta.style.opacity = pct >= 0.9 ? '1' : '0';
    }
    window.addEventListener('scroll', updateS8, { passive: true });
  }

  /* ── Scene 9: Strike-through pairs ───────────────────────── */
  var s9pairs = document.querySelectorAll('[data-s9-pair]');
  var s9flash = document.getElementById('s9-flash');
  var lastPair = s9pairs[s9pairs.length - 1];
  onEnter('[data-s9-pair]', function (el) { el.classList.add('fired'); }, { threshold: 0.4 });
  if (lastPair) {
    onEnter(lastPair, function () {
      setTimeout(function () {
        if (s9flash) {
          s9flash.classList.add('on');
          setTimeout(function () { s9flash.classList.remove('on'); }, 500);
        }
      }, 1200);
    }, { threshold: 0.8 });
  }

  /* ── Scene 11: Split items ────────────────────────────────── */
  onEnter('[data-trigger-side]', function (el) { el.classList.add('in'); }, { threshold: 0.15 });

  /* ── Scene 11 tagline + Scene 12 cards + Scene 16 cards ───── */
  onEnter('[data-trigger]', function (el) {
    el.classList.add('in');
    /* funnel fills */
    if (el.id === 's17') {
      el.querySelectorAll('.s17-row').forEach(function (r) { r.classList.add('fired'); });
    }
    /* counter strip */
    if (el.id === 's14') {
      el.querySelectorAll('[data-count]').forEach(function (num) {
        var target = parseFloat(num.getAttribute('data-count'));
        var suf = num.getAttribute('data-suffix') || '';
        var start = performance.now();
        var dur = 2000;
        (function tick(now) {
          var p = Math.min((now - start) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          num.textContent = Math.round(target * eased) + suf;
          if (p < 1) requestAnimationFrame(tick);
        })(start);
      });
    }
  }, { threshold: 0.2 });

  /* s12 cards individually */
  onEnter('.s12-card', function (el) { el.classList.add('in'); }, { threshold: 0.2 });
  onEnter('.v2-fade-in', function (el) { el.classList.add('in'); }, { threshold: 0.2 });

  /* ── Scene 13: Manifesto scroll ──────────────────────────── */
  var s13 = document.getElementById('s13');
  if (s13) {
    var s13lines = s13.querySelectorAll('[data-s13]');
    var S13TOTAL = s13lines.length;
    function updateS13() {
      var rect = s13.getBoundingClientRect();
      var scrollable = s13.offsetHeight - window.innerHeight;
      var pct = Math.max(0, Math.min(1, -rect.top / scrollable));
      s13lines.forEach(function (l, i) {
        var t = (i + 1) / (S13TOTAL + 1);
        l.classList.toggle('on', pct >= t);
      });
    }
    window.addEventListener('scroll', updateS13, { passive: true });
  }

  /* ── Nav opacity on scroll ───────────────────────────────── */
  var nav = document.getElementById('v2-nav');
  window.addEventListener('scroll', function () {
    var solid = window.scrollY > 80;
    nav.style.background = solid
      ? 'color-mix(in srgb, #0C0F14 85%, transparent)'
      : 'color-mix(in srgb, #0C0F14 55%, transparent)';
  }, { passive: true });

})();
</script>
</body>
</html>
