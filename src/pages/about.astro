---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../content/home";
---

<BaseLayout title="About" description={`About ${site.name} — full page coming soon.`} mainClass="main--narrow">
  <section class="placeholder-page" aria-labelledby="about-heading">
    <h1 id="about-heading">About</h1>
    <p class="lede">
      This page will hold your full story, timeline, and credibility details. For now, see the
      summary on the <a href="/#about">home page</a>.
    </p>
    <p class="prose">
      <a class="card-link" href="/">← Back to home</a>
    </p>
  </section>
</BaseLayout>
