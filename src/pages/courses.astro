---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../content/home";
---

<BaseLayout
  title="Courses"
  description={`Courses and programs by ${site.name} — coming soon.`}
  mainClass="main--narrow"
>
  <section class="placeholder-page" aria-labelledby="courses-heading">
    <h1 id="courses-heading">Courses</h1>
    <p class="lede">
      This section will host your curriculum, video lessons, and enrollment. Foundation is ready;
      content and video hosting will plug in here next.
    </p>
    <p class="prose">
      <a class="card-link" href="/">← Back to home</a>
    </p>
  </section>
</BaseLayout>
