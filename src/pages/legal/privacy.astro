---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../content/home";
---

<BaseLayout title="Privacy" description={`Privacy policy — ${site.name}.`} mainClass="main--narrow">
  <section class="placeholder-page" aria-labelledby="privacy-heading">
    <h1 id="privacy-heading">Privacy policy</h1>
    <p class="lede">Placeholder page. Replace with your real policy before collecting data or launching members.</p>
    <p class="prose">
      <a class="card-link" href="/">← Back to home</a>
    </p>
  </section>
</BaseLayout>
