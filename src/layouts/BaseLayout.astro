---
import "../styles/global.css";
import { mainNav } from "../navigation";
import { site } from "../content/home";

interface Props {
  title: string;
  description?: string;
  mainClass?: string;
}

const { title, description = site.defaultDescription, mainClass } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const pageTitle = `${title} — ${site.name}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem("theme");
          if (s === "light" || s === "dark") {
            document.documentElement.setAttribute("data-theme", s);
            return;
          }
        } catch (_) {}
        var light = window.matchMedia("(prefers-color-scheme: light)").matches;
        document.documentElement.setAttribute("data-theme", light ? "light" : "dark");
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <!-- Satoshi via Fontshare (free license on fontshare.com). Self-host: put .woff2 in public/fonts/ and use @font-face in global.css. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700,900&display=swap"
      rel="stylesheet"
    />
    <!-- Accent serif: Fraunces (Google Fonts, OFL). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />
    <!-- Analytics: add env-gated snippet in a future phase (e.g. Plausible, Fathom). -->
    <!-- Forms: POST to a Vercel serverless route, Astro server endpoint, or a third-party form action URL. -->
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="nav" aria-label="Primary">
        <a class="logo" href="/">{site.logoInitials}</a>
        <div class="nav-menu">
          <ul class="nav-links">
            {
              mainNav.map(({ href, label }) => {
                const normalized = href === "/" ? "/" : href.replace(/\/$/, "");
                const isCurrent =
                  normalized === "/"
                    ? pathname === "/"
                    : pathname === normalized || pathname.startsWith(`${normalized}/`);
                return (
                  <li>
                    <a href={href} aria-current={isCurrent ? "page" : undefined}>
                      {label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
          <div class="theme-switch" role="group" aria-label="Color theme">
            <button type="button" data-theme-pick="light">Light</button>
            <button type="button" data-theme-pick="dark">Dark</button>
          </div>
        </div>
      </nav>
    </header>

    <main id="main" class:list={[mainClass]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>
          © {new Date().getFullYear()}
          {site.name}. Built for personal branding.
        </p>
        <nav class="footer-legal" aria-label="Legal">
          <a href="/legal/privacy">Privacy</a>
          <a href="/legal/terms">Terms</a>
        </nav>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var root = document.documentElement;
        function current() {
          return root.getAttribute("data-theme") === "light" ? "light" : "dark";
        }
        function apply(theme) {
          root.setAttribute("data-theme", theme);
          try {
            localStorage.setItem("theme", theme);
          } catch (_) {}
          syncButtons();
        }
        function syncButtons() {
          var t = current();
          document.querySelectorAll("[data-theme-pick]").forEach(function (btn) {
            var v = btn.getAttribute("data-theme-pick");
            btn.setAttribute("aria-pressed", v === t ? "true" : "false");
          });
        }
        document.querySelectorAll("[data-theme-pick]").forEach(function (btn) {
          btn.addEventListener("click", function () {
            var v = btn.getAttribute("data-theme-pick");
            if (v === "light" || v === "dark") apply(v);
          });
        });
        syncButtons();
      })();
    </script>
  </body>
</html>
