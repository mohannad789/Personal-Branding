---
import "../styles/global.css";
import ThemeSwitch from "../components/ThemeSwitch.astro";
import { mainNav } from "../navigation";
import { site } from "../content/home";

interface Props {
  title: string;
  description?: string;
  mainClass?: string;
  /** `landing` = logo + single CTA only (theme toggle moves to footer). */
  navMode?: "full" | "landing";
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  title,
  description = site.defaultDescription,
  mainClass,
  navMode = "full",
  ctaHref = "/contact",
  ctaLabel = "Let's talk",
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const pageTitle = `${title} — ${site.name}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem("theme");
          if (s === "light" || s === "dark") {
            document.documentElement.setAttribute("data-theme", s);
            return;
          }
        } catch (_) {}
        var light = window.matchMedia("(prefers-color-scheme: light)").matches;
        document.documentElement.setAttribute("data-theme", light ? "light" : "dark");
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700,900&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class:list={["nav", navMode === "landing" && "nav--landing"]} aria-label="Primary">
        <a class="logo" href="/">{site.logoInitials}</a>
        {
          navMode === "landing" ? (
            <a class="btn btn-primary nav-cta" href={ctaHref}>
              {ctaLabel}
            </a>
          ) : (
            <div class="nav-menu">
              <ul class="nav-links">
                {mainNav.map(({ href, label }) => {
                  const normalized = href === "/" ? "/" : href.replace(/\/$/, "");
                  const isCurrent =
                    normalized === "/"
                      ? pathname === "/"
                      : pathname === normalized || pathname.startsWith(`${normalized}/`);
                  return (
                    <li>
                      <a href={href} aria-current={isCurrent ? "page" : undefined}>
                        {label}
                      </a>
                    </li>
                  );
                })}
              </ul>
              <ThemeSwitch />
            </div>
          )
        }
      </nav>
    </header>

    <main id="main" class:list={[mainClass]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>
          © {new Date().getFullYear()}
          {site.name}
        </p>
        <nav class="footer-legal" aria-label="Legal">
          <a href="/legal/privacy">Privacy</a>
          <a href="/legal/terms">Terms</a>
        </nav>
        {navMode === "landing" && <ThemeSwitch />}
      </div>
    </footer>
    <script is:inline>
      (function () {
        var root = document.documentElement;
        function current() {
          return root.getAttribute("data-theme") === "light" ? "light" : "dark";
        }
        function apply(theme) {
          root.setAttribute("data-theme", theme);
          try {
            localStorage.setItem("theme", theme);
          } catch (_) {}
          syncButtons();
        }
        function syncButtons() {
          var t = current();
          document.querySelectorAll("[data-theme-pick]").forEach(function (btn) {
            var v = btn.getAttribute("data-theme-pick");
            btn.setAttribute("aria-pressed", v === t ? "true" : "false");
          });
        }
        document.querySelectorAll("[data-theme-pick]").forEach(function (btn) {
          btn.addEventListener("click", function () {
            var v = btn.getAttribute("data-theme-pick");
            if (v === "light" || v === "dark") apply(v);
          });
        });
        syncButtons();
      })();
    </script>
  </body>
</html>
