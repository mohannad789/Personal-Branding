---
import "../styles/global.css";
import { site } from "../content/home";

interface Props {
  title: string;
  description?: string;
}

const { title, description = site.defaultDescription } = Astro.props;
const pageTitle = `${title} — ${site.name}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Inline theme detection — runs before first paint -->
    <script is:inline>
      (function () {
        function resolve(pref) {
          if (pref === "light" || pref === "dark") return pref;
          return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        }
        try {
          var s = localStorage.getItem("theme");
          if (s === "light" || s === "dark" || s === "system") {
            document.documentElement.setAttribute("data-theme", resolve(s));
            return;
          }
        } catch (_) {}
        document.documentElement.setAttribute("data-theme", resolve("system"));
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700,900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <!--
    body.is-landing — no <main> wrapper, no max-width constraints anywhere.
    All landing sections render directly as children of body.
  -->
  <body class="is-landing">
    <a class="skip-link" href="#lp-content">Skip to content</a>
    <slot />
  </body>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      function getPreference() {
        try {
          var s = localStorage.getItem("theme");
          if (s === "light" || s === "dark" || s === "system") return s;
        } catch (_) {}
        return "system";
      }
      function resolve(pref) {
        if (pref === "light" || pref === "dark") return pref;
        return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      }
      function applyPreference(pref) {
        root.setAttribute("data-theme", resolve(pref));
        try { localStorage.setItem("theme", pref); } catch (_) {}
        syncIcon();
      }
      function syncIcon() {
        var p = getPreference();
        document.querySelectorAll(".ti-icon").forEach(function (el) {
          el.classList.toggle("active", el.getAttribute("data-ti") === p);
        });
      }
      document.getElementById("theme-cycle-btn") && (function () {
        var btn = document.getElementById("theme-cycle-btn");
        var order = ["light", "dark", "system"];
        btn.addEventListener("click", function () {
          var current = getPreference();
          var next = order[(order.indexOf(current) + 1) % order.length];
          applyPreference(next);
        });
      })();
      var mql = window.matchMedia("(prefers-color-scheme: light)");
      function onScheme() {
        if (getPreference() === "system") root.setAttribute("data-theme", resolve("system"));
      }
      if (mql.addEventListener) mql.addEventListener("change", onScheme);
      else if (mql.addListener) mql.addListener(onScheme);
      document.querySelectorAll(".ti-icon").length && (function () {
        var p = getPreference();
        document.querySelectorAll(".ti-icon").forEach(function (el) {
          el.classList.toggle("active", el.getAttribute("data-ti") === p);
        });
      })();
    })();
  </script>
</html>
