---
import { landing } from "../../content/landing";
import VizReputationBrand from "./viz/VizReputationBrand.astro";
const s = landing.problem;
const [first, second, ...rest] = s.paragraphs;
---

<section class="lp-band lp-band--paper lp-problem" aria-labelledby="lp-problem-h">
  <div class="lp-container">
    <div class="lp-problem-top">
      <div class="lp-problem-label">
        <span class="lp-rule-label">The problem</span>
      </div>
      <h2 id="lp-problem-h" class="lp-editorial-h2">{s.title}</h2>
    </div>

    <blockquote class="lp-pull-quote">
      <p>"You're the best-kept secret in your industry. And that's not the compliment it sounds like."</p>
    </blockquote>

    <div class="lp-problem-split">
      <div class="lp-two-col-prose">
        <p class="lp-prose-lead">{first}</p>
        <div class="lp-prose-stack">
          <p>{second}</p>
          {rest.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <aside class="lp-problem-aside" aria-label="Illustrative chart">
        <VizReputationBrand />
      </aside>
    </div>
  </div>
</section>
