---
import { landing } from "../../content/landing";
const s = landing.problem;
const bodyParagraphs = s.paragraphs;
---

<section class="lp-section lp-section--light" aria-labelledby="lp-problem-h">
  <div class="lp-container">
    <div class="lp-problem-grid">
      <div class="lp-problem-left lp-anim--slide-left" data-anim>
        <span class="lp-eyebrow">The Problem</span>
        <h2 id="lp-problem-h" class="lp-h2">{s.title}</h2>
      </div>
      <div class="lp-problem-right lp-body lp-anim--slide-right" data-anim>
        {bodyParagraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <div class="lp-pull-quote lp-anim" data-anim>
      <p>{s.pullQuote}</p>
      <span class="lp-pull-quote-line" aria-hidden="true"></span>
    </div>
  </div>
</section>
