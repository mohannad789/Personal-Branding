<section class="hero sec">
  <div class="hero-mesh" aria-hidden="true"></div>
  <div class="hero-dots" aria-hidden="true"></div>

  <!-- hero-inner deliberately NOT inside .lc — uses its own wide padding -->
  <div class="hero-inner">
    <!-- Text content -->
    <div class="hero-content">
      <span class="eyebrow hero-el" style="--d:0s">Strategic Personal Branding</span>

      <h1 class="display hero-headline hero-el" style="--d:0.1s">
        Your expertise<br>closes deals.<br>
        <span class="hl-accent">Your brand</span><br>should open them.
      </h1>

      <p class="hero-sub hero-el" style="--d:0.22s">
        Strategic personal branding for entrepreneurs who've outgrown word of mouth,
        and need the market to catch up with what their clients already know.
      </p>

      <ul class="hero-adv hero-el" style="--d:0.32s" aria-label="Key advantages">
        <li>
          <span class="hero-adv-dot" aria-hidden="true"></span>
          Inbound leads from markets that have never heard your name
        </li>
        <li>
          <span class="hero-adv-dot" aria-hidden="true"></span>
          A brand position that sells before you enter the room
        </li>
        <li>
          <span class="hero-adv-dot" aria-hidden="true"></span>
          Shorter sales cycles with prospects who arrive pre-sold
        </li>
        <li>
          <span class="hero-adv-dot" aria-hidden="true"></span>
          Authority that compounds like equity
        </li>
      </ul>

      <div class="hero-cta hero-el" style="--d:0.42s">
        <a href="/contact" class="btn btn--primary">
          Book a Strategy Call
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <path d="M2 7.5h11M8.5 3l4.5 4.5L8.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Orbital brand diagram — uses explicit CSS vars with fallbacks on each element -->
    <div class="hero-visual-wrap hero-el" style="--d:0.18s" aria-hidden="true">
      <svg class="orbit-svg" viewBox="0 0 480 480">
        <defs>
          <radialGradient id="hero-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#4F8FF7" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#4F8FF7" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="hero-glow-l" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#2563EB" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#2563EB" stop-opacity="0"/>
          </radialGradient>
        </defs>

        <!-- Ambient glow -->
        <circle cx="240" cy="240" r="190" fill="url(#hero-glow)" class="orbit-bg-fill"/>

        <!-- Orbital rings — accent colour, very subtle -->
        <circle cx="240" cy="240" r="95" fill="none" style="stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1"/>
        <circle cx="240" cy="240" r="152" fill="none" style="stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1; opacity:0.7"/>
        <circle cx="240" cy="240" r="205" fill="none" style="stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1; opacity:0.4"/>

        <!-- Dashed ring on inner -->
        <circle cx="240" cy="240" r="95" fill="none" style="stroke: var(--accent, #2563EB); stroke-width:0.8; stroke-dasharray:5 18; opacity:0.35"/>

        <!-- Center node -->
        <circle cx="240" cy="240" r="36" style="fill: var(--accentSoft, rgba(37,99,235,0.1)); stroke: var(--accent, #2563EB); stroke-width:1.5; stroke-opacity:0.5"/>
        <circle cx="240" cy="240" r="20" style="fill: var(--accent, #2563EB); opacity:0.15"/>
        <circle cx="240" cy="240" r="10" style="fill: var(--accent, #2563EB)"/>

        <!-- NODE 1: Strategic Positioning — inner ring r=95 -->
        <g class="on1">
          <line x1="240" y1="240" x2="335" y2="240" style="stroke: var(--accent, #2563EB); stroke-opacity:0.2; stroke-width:0.75; fill:none"/>
          <circle cx="335" cy="240" r="6" style="fill: var(--accent, #2563EB)"/>
          <g transform="translate(335,240)">
            <g class="ol1">
              <rect x="-68" y="-32" width="136" height="24" rx="12" style="fill: var(--bg2, #fff); stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1"/>
              <text x="0" y="-16" text-anchor="middle" style="fill: var(--t1, #080D28); font-family: Inter, system-ui, sans-serif; font-size:10.5px; font-weight:500">Strategic Positioning</text>
            </g>
          </g>
        </g>

        <!-- NODE 2: Narrative & Messaging — middle ring r=152 -->
        <g class="on2">
          <line x1="240" y1="240" x2="392" y2="240" style="stroke: var(--accent, #2563EB); stroke-opacity:0.18; stroke-width:0.75; fill:none"/>
          <circle cx="392" cy="240" r="5.5" style="fill: var(--accent, #2563EB); opacity:0.8"/>
          <g transform="translate(392,240)">
            <g class="ol2">
              <rect x="-72" y="-32" width="144" height="24" rx="12" style="fill: var(--bg2, #fff); stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1"/>
              <text x="0" y="-16" text-anchor="middle" style="fill: var(--t1, #080D28); font-family: Inter, system-ui, sans-serif; font-size:10.5px; font-weight:500">Narrative &amp; Messaging</text>
            </g>
          </g>
        </g>

        <!-- NODE 3: Visibility Architecture — middle ring r=152, offset -->
        <g class="on3">
          <line x1="240" y1="240" x2="392" y2="240" style="stroke: var(--accent, #2563EB); stroke-opacity:0.18; stroke-width:0.75; fill:none"/>
          <circle cx="392" cy="240" r="5.5" style="fill: var(--accent, #2563EB); opacity:0.8"/>
          <g transform="translate(392,240)">
            <g class="ol3">
              <rect x="-68" y="-32" width="136" height="24" rx="12" style="fill: var(--bg2, #fff); stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1"/>
              <text x="0" y="-16" text-anchor="middle" style="fill: var(--t1, #080D28); font-family: Inter, system-ui, sans-serif; font-size:10.5px; font-weight:500">Visibility Architecture</text>
            </g>
          </g>
        </g>

        <!-- NODE 4: Conversion Infrastructure — outer ring r=205 -->
        <g class="on4">
          <line x1="240" y1="240" x2="445" y2="240" style="stroke: var(--accent, #2563EB); stroke-opacity:0.15; stroke-width:0.75; fill:none"/>
          <circle cx="445" cy="240" r="5" style="fill: var(--accent, #2563EB); opacity:0.65"/>
          <g transform="translate(445,240)">
            <g class="ol4">
              <rect x="-76" y="-32" width="152" height="24" rx="12" style="fill: var(--bg2, #fff); stroke: var(--accentRim, rgba(37,99,235,0.22)); stroke-width:1"/>
              <text x="0" y="-16" text-anchor="middle" style="fill: var(--t1, #080D28); font-family: Inter, system-ui, sans-serif; font-size:10.5px; font-weight:500">Conversion Infrastructure</text>
            </g>
          </g>
        </g>
      </svg>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true"></div>
</section>

<style>
.hero-el {
  opacity: 0;
  transform: translateY(24px);
  animation: hero-in 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
  animation-delay: var(--d, 0s);
}

@keyframes hero-in {
  to { opacity: 1; transform: none; }
}
</style>
