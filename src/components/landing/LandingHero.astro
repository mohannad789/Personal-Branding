                 N1: 83%,50% = (398,240) — right, middle ring
                 N2: 50%,85% = (240,408) — bottom, outer ring
                 N3: 20%,32% = (96,154)  — top-left, middle ring
                 N4: 78%,17% = (374,82)  — top-right, outer ring -->
            <line x1="240" y1="240" x2="398" y2="240" class="hd-line"/>
            <line x1="240" y1="240" x2="240" y2="408" class="hd-line"/>
            <line x1="240" y1="240" x2="96"  y2="154" class="hd-line"/>
            <line x1="240" y1="240" x2="374" y2="82"  class="hd-line"/>
          </svg>

