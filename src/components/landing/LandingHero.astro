---
import { landing } from "../../content/landing";
import LandingIconCheck from "./LandingIconCheck.astro";
const h = landing.hero;
---

<section class="lp-hero lp-band--hero" aria-labelledby="lp-hero-h">
  <div class="lp-hero-wrap">
    <div class="lp-hero-stage">
      <div class="lp-hero-eyebrow-row">
        <span class="lp-chip">Personal Branding</span>
        <span class="lp-chip">Strategic Positioning</span>
        <span class="lp-chip">Revenue Architecture</span>
      </div>

      <h1 id="lp-hero-h" class="lp-hero-headline">
        <span class="lp-hero-headline-serif">Your expertise</span>
        <span class="lp-hero-headline-weight">closes deals.</span>
        <span class="lp-hero-headline-serif lp-hero-headline-serif--indent">Your brand</span>
        <span class="lp-hero-headline-weight">should open them.</span>
      </h1>

      <div class="lp-hero-body">
        <p class="lp-hero-sub">
          {h.sub}
        </p>
        <div class="lp-hero-action">
          <a class="btn btn-primary lp-btn-hero" href={h.ctaHref}>{h.ctaLabel}</a>
          <p class="lp-hero-meta">Dubai-based · DACH & Gulf</p>
        </div>
      </div>
    </div>

    <div class="lp-hero-advantages">
      {
        h.advantages.map((line) => (
          <div class="lp-adv-item">
            <span class="lp-adv-icon" aria-hidden="true">
              <LandingIconCheck />
            </span>
            <span class="lp-adv-text">{line}</span>
          </div>
        ))
      }
    </div>

    <div class="lp-hero-visual">
      <div class="lp-hero-img-frame">
        <img
          src={landing.visuals.hero}
          alt=""
          width="960"
          height="820"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="lp-hero-img"
        />
        <div class="lp-hero-img-overlay" aria-hidden="true"></div>
      </div>
      <div class="lp-hero-stat-row">
        <div class="lp-hero-stat">
          <span class="lp-hero-stat-num">8–12<small>wk</small></span>
          <span class="lp-hero-stat-label">Inbound shift</span>
        </div>
        <div class="lp-hero-stat-div" aria-hidden="true"></div>
        <div class="lp-hero-stat">
          <span class="lp-hero-stat-num">100%</span>
          <span class="lp-hero-stat-label">Custom strategy</span>
        </div>
        <div class="lp-hero-stat-div" aria-hidden="true"></div>
        <div class="lp-hero-stat">
          <span class="lp-hero-stat-num">0</span>
          <span class="lp-hero-stat-label">Recycled playbooks</span>
        </div>
      </div>
    </div>
  </div>
</section>
