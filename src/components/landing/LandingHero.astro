<style>
/* ─── Hero — all styles self-contained, no class conflicts ───────────────── */

.lp-hero {
  /* Section fills body width. Body.is-landing has no max-width. */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100svh;
  padding: clamp(7rem, 12vw, 11rem) clamp(1.5rem, 5vw, 3.5rem) clamp(5rem, 8vw, 8rem);
  position: relative;
  overflow: hidden;
  text-align: center;
}

/* Vanta injects its own canvas — reduce opacity so it never competes with text */
.lp-hero canvas {
  opacity: 0.55;
}

:root[data-theme="dark"] .lp-hero canvas {
  opacity: 0.45;  /* even more recessed in dark mode */
}

/* Content column — max-width just controls line length, section is still 100% wide */
.lp-hero-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.75rem;
  max-width: 860px;
  width: 100%;
  animation: lp-hero-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  animation-delay: 0.05s;
}

@keyframes lp-hero-in {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: none; }
}

/* Eyebrow */
.lp-hero-eyebrow {
  display: inline-block;
  font-family: var(--fB, "Inter", sans-serif);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent, #4F8FF7);
}

/* Main headline */
.lp-hero-h1 {
  font-family: var(--fH, "Satoshi", sans-serif);
  font-weight: 800;
  font-size: clamp(2.75rem, 6vw, 5.5rem);
  line-height: 1.06;
  letter-spacing: -0.04em;
  color: var(--t1, #DCE4FF);
  margin: 0;
}

.lp-hero-h1-accent {
  color: var(--accent, #4F8FF7);
}

/* Sub headline */
.lp-hero-sub {
  font-family: var(--fB, "Inter", sans-serif);
  font-size: clamp(1rem, 1.5vw, 1.175rem);
  line-height: 1.75;
  color: var(--t2, #7A8DB5);
  max-width: 52ch;
  margin: 0;
}

/* Advantages grid */
.lp-hero-adv {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.625rem;
  width: 100%;
  max-width: 700px;
  text-align: left;
}

@media (max-width: 560px) {
  .lp-hero-adv { grid-template-columns: 1fr; }
}

.lp-hero-adv li {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  font-family: var(--fB, "Inter", sans-serif);
  font-size: 0.9rem;
  color: var(--t2, #7A8DB5);
  line-height: 1.55;
  padding: 0.75rem 1rem;
  background: var(--gBg, rgba(11,14,28,0.6));
  border: 1px solid var(--gB, rgba(255,255,255,0.09));
  border-radius: 12px;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.lp-hero-adv li::before {
  content: '';
  flex-shrink: 0;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent, #4F8FF7);
  margin-top: 6px;
  opacity: 0.75;
}

/* CTA button */
.lp-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1.0625rem 2.75rem;
  font-family: var(--fB, "Inter", sans-serif);
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  background: var(--accent, #4F8FF7);
  border: none;
  border-radius: 999px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.25s, transform 0.2s;
  margin-top: 0.5rem;
}

.lp-hero-cta:hover {
  background: var(--accentH, #6FA5FF);
  transform: translateY(-2px);
}

/* Scroll cue */
.lp-hero-cue {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, transparent, var(--accent, #4F8FF7), transparent);
  animation: lp-cue-pulse 2.5s ease-in-out infinite;
}

@keyframes lp-cue-pulse {
  0%, 100% { opacity: 0.15; }
  50%       { opacity: 0.55; }
}

.lp-hero-mesh,
.lp-hero-dots { display: none; } /* kept in case JS is unavailable */

@media (prefers-reduced-motion: reduce) {
  .lp-hero-body { animation: none; opacity: 1; transform: none; }
  .lp-hero-cue  { animation: none; }
}
</style>

<script is:inline>
(function () {
  /* ── Vanta NET hero background ─────────────────────────────────────────── */

  var vantaInstance = null;

  /* Colour palettes per theme — kept very close to bg so the net is subtle */
  var THEMES = {
    dark: {
      backgroundColor: 0x05080f,
      color:           0x0e1f3d,   /* near-bg dark blue — barely visible */
      color2:          0x0a1528
    },
    light: {
      backgroundColor: 0xf2f5ff,
      color:           0xbed0ef,   /* pale blue — washes into the light bg */
      color2:          0xd2e0f6
    }
  };

  function currentTheme() {
    return document.documentElement.getAttribute("data-theme") === "light"
      ? "light"
      : "dark";
  }

  function initVanta() {
    if (typeof VANTA === "undefined" || !VANTA.NET) return;

    /* Destroy previous instance before re-creating (theme switch) */
    if (vantaInstance) {
      vantaInstance.destroy();
      vantaInstance = null;
    }

    var palette = THEMES[currentTheme()];

    vantaInstance = VANTA.NET({
      el:            "#hero",
      THREE:         THREE,
      mouseControls: true,
      touchControls: true,
      gyroControls:  false,
      minHeight:     200,
      minWidth:      200,
      scale:         1.00,
      scaleMobile:   1.00,
      points:        9.00,
      maxDistance:   16.00,
      spacing:       20.00,
      backgroundColor: palette.backgroundColor,
      color:           palette.color,
      color2:          palette.color2
    });
  }

  /* Init once Three.js + Vanta are ready */
  function tryInit() {
    if (typeof THREE !== "undefined" && typeof VANTA !== "undefined" && VANTA.NET) {
      initVanta();
    } else {
      setTimeout(tryInit, 80);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", tryInit);
  } else {
    tryInit();
  }

  /* Re-init when theme changes so colours stay in sync */
  var prevTheme = currentTheme();
  var obs = new MutationObserver(function () {
    var t = currentTheme();
    if (t !== prevTheme) {
      prevTheme = t;
      initVanta();
    }
  });
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
})();
</script>
