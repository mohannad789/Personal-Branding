---
import { landing } from "../../content/landing";
const h = landing.hero;
---

<section class="lp-hero" aria-labelledby="lp-hero-h">
  <div class="lp-hero-grain" aria-hidden="true"></div>

  <div class="lp-hero-content">
    <h1 id="lp-hero-h" class="lp-anim" data-anim>{h.headline}</h1>

    <p class="lp-hero-sub lp-anim" data-anim style="transition-delay: 0.2s;">{h.sub}</p>

    <ul class="lp-hero-advantages">
      {h.advantages.map((line, i) => (
        <li class="lp-anim" data-anim style={`transition-delay: ${0.4 + i * 0.1}s;`}>{line}</li>
      ))}
    </ul>

    <div class="lp-anim" data-anim style="transition-delay: 0.9s;">
      <a class="lp-btn-accent" href={h.ctaHref}>{h.ctaLabel}</a>
    </div>
  </div>

  <div class="lp-hero-scroll" aria-hidden="true">
    <span class="lp-hero-scroll-line"></span>
  </div>
</section>
