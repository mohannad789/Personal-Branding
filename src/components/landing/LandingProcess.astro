---
import { landing } from "../../content/landing";
import InfographicCompound from "./infographics/InfographicCompound.astro";

const s = landing.process;
---

<section class="lp-section" id="process" aria-labelledby="lp-process-h">
  <div class="lp-container">
    <div class="lp-process-header lp-anim" data-anim>
      <span class="lp-eyebrow">The Process</span>
      <h2 id="lp-process-h" class="lp-h2" style="margin-inline: auto; max-width: 22ch; text-align: center;">{s.title}</h2>
    </div>

    <div class="lp-process-timeline lp-anim" data-anim style="transition-delay: 0.3s;">
      <div class="lp-process-line" aria-hidden="true">
        <div class="lp-process-line-fill"></div>
      </div>

      {s.steps.map((step, i) => (
        <div class="lp-step">
          <div class="lp-step-circle">{i + 1}</div>
          <h3 class="lp-step-title">{step.title}</h3>
          <p class="lp-step-body">{step.body}</p>
        </div>
      ))}
    </div>

    <InfographicCompound />
  </div>
</section>
