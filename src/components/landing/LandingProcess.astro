---
import { landing } from "../../content/landing";
const s = landing.process;
---

<section class="lp-band lp-band--dim" aria-labelledby="lp-process-h">
  <div class="lp-section-inner lp-section-inner--wide">
    <h2 id="lp-process-h" class="lp-section-title">{s.title}</h2>
    <ol class="lp-process-steps">
      {s.steps.map((step, i) => (
        <li class="lp-process-step">
          <span class="lp-process-step-num" aria-hidden="true">
            {i + 1}
          </span>
          <div class="lp-process-step-body">
            <h3 class="lp-process-step-title">{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
