---
import { landing } from "../../content/landing";
const m = landing.mirror;
---

<section class="lp-mirror lp-band lp-band--paper" aria-label="The mirror">
  <div class="lp-prose lp-prose--wide">
    <p>{m.openEn}</p>
    <p>{m.recognitionEn}</p>
    <blockquote class="lp-pull-de font-accent" lang="de">
      {m.pullDe}
    </blockquote>
    <p>{m.diagnosisEn}</p>
  </div>
</section>
