---
import { landing } from "../../content/landing";
const s = landing.who;
const lastP = s.paragraphs[s.paragraphs.length - 1];
const bodyPs = s.paragraphs.slice(0, -1);
---

<section class="lp-section lp-section--light" aria-labelledby="lp-who-h">
  <div class="lp-container">
    <div class="lp-who-grid">
      <div class="lp-who-left lp-anim--slide-left" data-anim>
        <span class="lp-eyebrow">Who This Is For</span>
        <h2 id="lp-who-h" class="lp-h2">{s.title}</h2>
      </div>

      <div class="lp-who-divider" aria-hidden="true"></div>

      <div class="lp-who-right lp-body lp-anim--slide-right" data-anim>
        {bodyPs.map((p) => <p>{p}</p>)}
        <p class="lp-who-closing">{lastP}</p>
      </div>
    </div>
  </div>
</section>
