---
/** Visualises reputation (proximity) vs brand (scalable reach). */
---
<div class="lp-viz lp-chart-bars" data-viz>
  <div class="lp-viz-head">
    <p class="lp-viz-kicker">The gap</p>
    <p class="lp-viz-title">Reputation vs brand — who can buy from you?</p>
    <p class="lp-viz-note">
      Reputation converts people who already know you. Brand is what lets strangers arrive pre-sold.
    </p>
  </div>
  <div class="lp-viz-bars" role="img" aria-label="Bar comparison: small bar reputation inside network, long bar brand across markets">
    <div class="lp-hbar">
      <span class="lp-hbar-label">Inside your existing network</span>
      <div class="lp-hbar-track">
        <div class="lp-hbar-fill lp-hbar-fill--muted" style="--w: 32%"></div>
      </div>
      <span class="lp-hbar-cap">Reputation</span>
    </div>
    <div class="lp-hbar">
      <span class="lp-hbar-label">Markets that have never heard your name</span>
      <div class="lp-hbar-track">
        <div class="lp-hbar-fill lp-hbar-fill--accent" style="--w: 100%"></div>
      </div>
      <span class="lp-hbar-cap">Brand position</span>
    </div>
  </div>
</div>
