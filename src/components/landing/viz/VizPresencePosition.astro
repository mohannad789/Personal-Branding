---
/** Presence (volume) vs position (precision) — matches shift copy. */
---
<div class="lp-viz lp-viz--on-dark lp-chart-bars" data-viz>
  <div class="lp-viz-head">
    <p class="lp-viz-kicker">Presence vs position</p>
    <p class="lp-viz-title">Where the budget actually goes</p>
    <p class="lp-viz-note">
      Presence optimises for activity. Position optimises for the specific perception that drives revenue.
    </p>
  </div>
  <div class="lp-viz-bars lp-viz-bars--dark" role="img" aria-label="Three wide grey bars for posts pixels platforms, one long accent bar for precision">
    <div class="lp-hbar lp-hbar--dark">
      <span class="lp-hbar-label">Posts · pixels · platforms (volume)</span>
      <div class="lp-hbar-track lp-hbar-track--dark">
        <div class="lp-hbar-fill lp-hbar-fill--ghost" style="--w: 92%"></div>
      </div>
    </div>
    <div class="lp-hbar lp-hbar--dark">
      <span class="lp-hbar-label">Right perception · right rooms · right people</span>
      <div class="lp-hbar-track lp-hbar-track--dark">
        <div class="lp-hbar-fill lp-hbar-fill--accent" style="--w: 44%"></div>
      </div>
      <span class="lp-hbar-cap lp-hbar-cap--light">Precision (harder, smaller surface — higher leverage)</span>
    </div>
  </div>
</div>
