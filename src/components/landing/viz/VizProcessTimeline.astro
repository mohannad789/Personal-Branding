---
const steps = ["Diagnosis", "Strategy", "Build", "Compound"];
---
<div class="lp-viz lp-chart-timeline" data-viz>
  <div class="lp-viz-head">
    <p class="lp-viz-kicker">Linear dependency</p>
    <p class="lp-viz-title">Nothing moves without the prior step</p>
    <p class="lp-viz-note">Build is custom work, but strategy is the constraint. Compound is where position appreciates.</p>
  </div>
  <div class="lp-timeline" role="img" aria-label="Four connected steps: diagnosis strategy build compound">
    <div class="lp-timeline-rail" aria-hidden="true">
      <span class="lp-timeline-line"></span>
    </div>
    <ol class="lp-timeline-steps" role="list">
      {
        steps.map((label, i) => (
          <li class="lp-timeline-step" style={`--ti:${i}`}>
            <span class="lp-timeline-dot">{i + 1}</span>
            <span class="lp-timeline-label">{label}</span>
          </li>
        ))
      }
    </ol>
  </div>
</div>
