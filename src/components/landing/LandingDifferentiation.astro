---
import { landing } from "../../content/landing";
const s = landing.differentiation;
---

<section class="lp-band lp-band--ink lp-diff" aria-labelledby="lp-diff-h">
  <div class="lp-container">
    <div class="lp-diff-grid">
      <div class="lp-diff-left">
        <span class="lp-rule-label lp-rule-label--light">Differentiation</span>
        <h2 id="lp-diff-h" class="lp-diff-headline">{s.title}</h2>
        <p class="lp-diff-crossed">{s.paragraphs[0]}</p>
      </div>
      <div class="lp-diff-right">
        <div class="lp-diff-card">
          <span class="lp-diff-card-label">What you won't get elsewhere</span>
          {s.paragraphs.slice(1).map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </div>
</section>
