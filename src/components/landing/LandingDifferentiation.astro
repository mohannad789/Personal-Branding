---
import { landing } from "../../content/landing";
const s = landing.differentiation;
---

<section class="lp-section lp-section--light" aria-labelledby="lp-diff-h">
  <div class="lp-container">
    <span class="lp-eyebrow lp-anim" data-anim>The Difference</span>

    <div class="lp-diff-statements">
      {s.negatives.map((stmt, i) => (
        <p class="lp-diff-statement lp-anim" data-anim style={`transition-delay: ${i * 0.3}s;`}>{stmt}</p>
      ))}
    </div>

    <div class="lp-diff-positive lp-body lp-anim" data-anim>
      <p>{s.positive}</p>
      <p class="lp-diff-signature">{s.signature}</p>
    </div>
  </div>
</section>
