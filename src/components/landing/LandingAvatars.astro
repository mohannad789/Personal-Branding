---
import { landing } from "../../content/landing";
---

<section class="lp-avatars lp-band lp-band--paper" aria-labelledby="lp-avatars-h">
  <div class="lp-avatars-inner">
    <h2 id="lp-avatars-h" class="lp-section-label">Who it's for</h2>
    <div class="lp-avatar-grid">
      {
        landing.avatars.cards.map((c) => (
          <article class="lp-avatar-card">
            <h3 class="lp-avatar-title">{c.title}</h3>
            <p class="lp-avatar-body">{c.bodyEn}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
