---
import { landing } from "../../content/landing";
const s = landing.faq;
---

<section class="lp-band lp-band--paper lp-faq-section" aria-labelledby="lp-faq-h">
  <div class="lp-container lp-container--narrow">
    <div class="lp-faq-header">
      <span class="lp-rule-label">Questions</span>
      <h2 id="lp-faq-h" class="lp-editorial-h2">FAQ</h2>
    </div>
    <div class="lp-faq-list">
      {
        s.items.map((item) => (
          <details class="lp-faq-item" name="landing-faq">
            <summary class="lp-faq-q">{item.q}</summary>
            <p class="lp-faq-a">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
