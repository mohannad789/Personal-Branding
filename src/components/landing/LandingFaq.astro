---
import { landing } from "../../content/landing";
const s = landing.faq;
---

<section class="lp-band lp-band--dim lp-faq-section" aria-labelledby="lp-faq-h">
  <div class="lp-container lp-container--narrow">
    <div class="lp-section-head lp-section-head--center">
      <p class="lp-eyebrow">Questions</p>
      <h2 id="lp-faq-h" class="lp-section-title lp-section-title--center">{s.title}</h2>
    </div>
    <div class="lp-faq-list">
      {
        s.items.map((item) => (
          <details class="lp-faq-item" name="landing-faq">
            <summary class="lp-faq-q">{item.q}</summary>
            <p class="lp-faq-a">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
