---
import { landing } from "../../content/landing";
const s = landing.services;
---

<section class="lp-band lp-band--dim lp-services" aria-labelledby="lp-services-h">
  <div class="lp-container">
    <div class="lp-services-header">
      <div>
        <span class="lp-rule-label">What we do</span>
        <h2 id="lp-services-h" class="lp-editorial-h2">{s.title}</h2>
      </div>
      <p class="lp-services-intro-text">{s.intro}</p>
    </div>

    <ol class="lp-services-list" role="list">
      {
        s.pillars.map((pillar, i) => (
          <li class="lp-service-row">
            <span class="lp-service-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
            <div class="lp-service-content">
              <h3 class="lp-service-title">{pillar.title}</h3>
              <p class="lp-service-body">{pillar.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
