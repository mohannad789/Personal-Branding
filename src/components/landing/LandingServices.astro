---
import { landing } from "../../content/landing";
const s = landing.services;
---

<section class="lp-section" id="services" aria-labelledby="lp-services-h">
  <div class="lp-container">
    <div class="lp-services-header lp-anim" data-anim>
      <span class="lp-eyebrow">What We Do</span>
      <h2 id="lp-services-h" class="lp-h2" style="margin-inline: auto; max-width: 24ch; text-align: center;">{s.title}</h2>
      <div class="lp-body">
        <p>{s.intro}</p>
      </div>
    </div>

    <div class="lp-services-grid">
      {s.pillars.map((pillar, i) => (
        <article class="lp-service-card lp-anim" data-anim style={`transition-delay: ${i * 0.15}s;`}>
          <span class="lp-service-num">0{i + 1}</span>
          <h3 class="lp-service-title">{pillar.title}</h3>
          <p class="lp-service-body">{pillar.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
