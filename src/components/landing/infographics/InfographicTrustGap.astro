---
const rows = [
  {
    label: "Buyers who trust a founder's personal content over corporate marketing",
    pct: 82,
  },
  {
    label: "B2B decisions influenced by the seller's personal reputation",
    pct: 73,
  },
  {
    label: "Executives who say thought leadership directly influenced a purchasing decision",
    pct: 65,
  },
];
---

<div class="ig ig-card ig-trust" data-ig>
  <span class="ig-eyebrow">The trust economy</span>
  <div class="ig-trust-rows">
    {
      rows.map((r) => (
        <div class="ig-trust-row">
          <p class="ig-trust-label">{r.label}</p>
          <div class="ig-trust-bar-row">
            <div class="ig-trust-track" style={`--ig-pct: ${r.pct}%`}>
              <div class="ig-trust-fill" />
              <span class="ig-trust-dot" aria-hidden="true" />
            </div>
            <span class="ig-trust-num">{r.pct}%</span>
          </div>
        </div>
      ))
    }
  </div>
  <p class="ig-source">
    Sources: Edelman Trust Barometer 2024, LinkedIn B2B Thought Leadership Impact Study
  </p>
</div>
