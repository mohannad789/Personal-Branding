<div class="ig ig-card ig-chart-wrap" data-ig>
  <span class="ig-eyebrow">The compound effect</span>
  <svg
    class="ig-chart-svg"
    viewBox="0 0 680 320"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="ig-compound-fill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--lp-accent)" stop-opacity="0.14" />
        <stop offset="100%" stop-color="var(--lp-accent)" stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- grid -->
    <g stroke="rgba(255,255,255,0.04)" stroke-width="0.5">
      <line x1="56" y1="52" x2="624" y2="52" />
      <line x1="56" y1="100" x2="624" y2="100" />
      <line x1="56" y1="148" x2="624" y2="148" />
      <line x1="56" y1="196" x2="624" y2="196" />
    </g>

    <text x="8" y="58" fill="var(--lp-ig-source)" font-size="10" font-family="Inter, sans-serif">High impact</text>
    <text x="8" y="248" fill="var(--lp-ig-source)" font-size="10" font-family="Inter, sans-serif">Low impact</text>

    <text x="56" y="278" fill="var(--lp-ig-source)" font-size="10" font-family="Inter, sans-serif">1</text>
    <text x="608" y="278" fill="var(--lp-ig-source)" font-size="10" font-family="Inter, sans-serif">12</text>
    <text x="320" y="298" fill="var(--lp-ig-source)" font-size="10" font-family="Inter, sans-serif" text-anchor="middle">Months</text>

    <path
      id="ig-campaign-line"
      class="ig-line-campaign"
      stroke="#5c5c5c"
      d="M56 120 L108 72 L160 168 L212 88 L264 152 L316 96 L368 144 L420 112 L472 136 L524 104 L576 128 L624 120"
    />

    <path
      id="ig-brand-area"
      class="ig-area-brand"
      fill="url(#ig-compound-fill)"
      d="M56 200 L56 184 Q140 168 220 140 T400 72 L624 40 L624 244 L56 244 Z"
      opacity="0"
    />

    <path
      class="ig-line-brand"
      stroke="var(--lp-accent)"
      d="M56 200 Q140 176 200 150 T360 88 T624 40"
    />

    <circle class="ig-cross-dot" cx="280" cy="118" r="5" fill="var(--lp-accent)" opacity="0" />

    <text x="520" y="36" fill="var(--lp-ig-source)" font-size="11" font-family="Inter, sans-serif">Campaign bursts</text>
    <text x="520" y="52" fill="var(--lp-accent)" font-size="11" font-family="Inter, sans-serif">Brand position</text>
  </svg>
</div>

<style is:global>
  .ig-line-campaign,
  .ig-line-brand {
    stroke-dasharray: 900;
    stroke-dashoffset: 900;
    transition: stroke-dashoffset 2.5s ease-out;
  }

  .ig--visible .ig-line-campaign,
  .ig--visible .ig-line-brand {
    stroke-dashoffset: 0;
  }

  .ig-area-brand {
    transition: opacity 0.45s ease 2.4s;
  }

  .ig--visible .ig-area-brand {
    opacity: 1;
  }

  .ig-cross-dot {
    transition: opacity 0.4s ease 2.2s;
    filter: drop-shadow(0 0 8px var(--lp-accent-glow));
  }

  .ig--visible .ig-cross-dot {
    opacity: 0.85;
    animation: ig-cross-pulse 2.5s ease-in-out infinite;
  }

  @keyframes ig-cross-pulse {
    0%,
    100% {
      opacity: 0.45;
    }
    50% {
      opacity: 0.95;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ig-line-campaign,
    .ig-line-brand {
      transition: none !important;
      stroke-dashoffset: 0 !important;
    }

    .ig-area-brand {
      opacity: 1 !important;
      transition: none !important;
    }

    .ig-cross-dot {
      animation: none !important;
      opacity: 0.85 !important;
    }
  }
</style>
