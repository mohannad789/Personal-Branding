---
import { landing } from "../../content/landing";

const s = landing.proof;
---

<section class="lp-section" aria-labelledby="lp-proof-h">
  <div class="lp-container">
    <div class="lp-proof-header lp-anim" data-anim>
      <span class="lp-eyebrow">Client Outcomes</span>
      <h2 id="lp-proof-h" class="lp-h2" style="margin-inline: auto; max-width: 28ch; text-align: center;">{s.title}</h2>
    </div>

    <div class="lp-testimonials">
      {s.placeholderCards.map((card, i) => (
        <article class="lp-testimonial lp-anim" data-anim style={`transition-delay: ${i * 0.15}s;`}>
          <blockquote class="lp-testimonial-quote">{card.quote}</blockquote>
          <footer>
            <span class="lp-testimonial-name">{card.attribution}</span>
            <span class="lp-testimonial-role">{card.company}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
