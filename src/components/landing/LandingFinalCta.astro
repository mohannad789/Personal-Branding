---
import { landing } from "../../content/landing";
const s = landing.finalCta;
---

<section class="lp-band lp-final" aria-labelledby="lp-final-h">
  <!-- Subtly pulsing glow background -->
  <div style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(circle at 50% 50%, rgba(94, 164, 252, 0.1), transparent 70%); animation: pulse 4s ease-in-out infinite alternate;"></div>
  
  <div class="lp-container lp-fade-in" data-viz>
    <div class="lp-final-inner">
      <span class="lp-eyebrow">Next step</span>
      <h2 id="lp-final-h" class="lp-h2">{s.headline}</h2>
      <p>{s.body}</p>
      
      <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; margin-top: 2.5rem;">
        <a class="btn lp-btn-lg lp-btn-ink" href={s.ctaHref}>{s.ctaLabel}</a>
        <p style="font-size: 0.85rem; color: rgba(255,255,255,0.4); letter-spacing: 0.05em;">{s.supportingLine}</p>
      </div>
    </div>
  </div>
  
  <style>
    @keyframes pulse {
      0% { opacity: 0.5; transform: scale(0.95); }
      100% { opacity: 1; transform: scale(1.05); }
    }
  </style>
</section>
