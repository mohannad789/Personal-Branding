---
import { landing } from "../../content/landing";
const s = landing.finalCta;
---

<section class="lp-band lp-band--ink lp-final" aria-labelledby="lp-final-h">
  <div class="lp-container">
    <div class="lp-final-inner">
      <span class="lp-rule-label lp-rule-label--light">Next step</span>
      <h2 id="lp-final-h" class="lp-final-headline">{s.headline}</h2>
      <p class="lp-final-body">{s.body}</p>
      <div class="lp-final-action">
        <a class="btn btn-primary lp-btn-ink" href={s.ctaHref}>{s.ctaLabel}</a>
        <p class="lp-final-support">{s.supportingLine}</p>
      </div>
    </div>
  </div>
</section>
