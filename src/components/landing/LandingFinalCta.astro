---
import { landing } from "../../content/landing";
const s = landing.finalCta;
---

<section class="lp-section lp-final-cta" aria-labelledby="lp-final-h">
  <div class="lp-final-glow" aria-hidden="true"></div>

  <div class="lp-final-cta-inner">
    <span class="lp-eyebrow lp-anim" data-anim>Next Step</span>
    <h2 id="lp-final-h" class="lp-h2 lp-anim" data-anim style="transition-delay: 0.15s;">{s.headline}</h2>
    <div class="lp-body lp-anim" data-anim style="transition-delay: 0.3s;">
      <p>{s.body}</p>
    </div>
    <div class="lp-anim" data-anim style="transition-delay: 0.45s;">
      <a class="lp-btn-accent lp-btn-accent--lg lp-btn-pulse" href={s.ctaHref}>{s.ctaLabel}</a>
      <p class="lp-final-support">{s.supportingLine}</p>
    </div>
  </div>
</section>
