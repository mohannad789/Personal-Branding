---
import { landing } from "../../content/landing";
const o = landing.offer;

const icons = {
  target: `<svg class="lp-pillar-icon" viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="12" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="16" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/></svg>`,
  signal: `<svg class="lp-pillar-icon" viewBox="0 0 32 32" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M6 22v-4M12 22V10M18 22V14M24 22V6"/></svg>`,
  rise: `<svg class="lp-pillar-icon" viewBox="0 0 32 32" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M8 20l6-6 4 4 8-10M20 8h6v6"/></svg>`,
} as const;
---

<section class="lp-offer lp-band lp-band--paper" aria-labelledby="lp-offer-h">
  <div class="lp-offer-inner">
    <h2 id="lp-offer-h" class="lp-section-label">What we do</h2>
    <div class="lp-prose lp-prose--tight">
      <p class="lp-lead">{o.leadEn}</p>
      <p>{o.bodyEn}</p>
    </div>
    <div class="lp-pillars" role="list">
      {
        o.pillars.map((p) => (
          <div class="lp-pillar" role="listitem">
            <div class="lp-pillar-icon-wrap" set:html={icons[p.icon]} />
            <span class="lp-pillar-label">{p.label}</span>
          </div>
        ))
      }
    </div>
    <p class="lp-caption-de" lang="de">{o.captionDe}</p>
  </div>
</section>
