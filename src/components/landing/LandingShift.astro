---
import { landing } from "../../content/landing";
const s = landing.shift;
---

<section class="lp-band lp-band--dim" aria-labelledby="lp-shift-h">
  <div class="lp-section-inner">
    <h2 id="lp-shift-h" class="lp-section-title">{s.title}</h2>
    <div class="lp-prose lp-prose--wide">
      {s.paragraphs.map((p) => (
        <p>{p}</p>
      ))}
    </div>
    <p class="lp-section-cta">
      <a class="btn btn-primary" href={s.ctaHref}>{s.ctaLabel}</a>
    </p>
  </div>
</section>
