---
import { landing } from "../../content/landing";
const s = landing.shift;
const [first, ...rest] = s.paragraphs;
---

<section class="lp-band lp-band--ink lp-shift" aria-labelledby="lp-shift-h">
  <div class="lp-container">
    <div class="lp-shift-header">
      <span class="lp-rule-label lp-rule-label--light">The shift</span>
      <h2 id="lp-shift-h" class="lp-shift-headline">{s.title}</h2>
    </div>

    <div class="lp-shift-body">
      <p class="lp-shift-lead">{first}</p>
      <div class="lp-shift-cols">
        {rest.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <div class="lp-shift-cta-row">
      <a class="btn btn-primary lp-btn-ink" href={s.ctaHref}>{s.ctaLabel}</a>
      <span class="lp-shift-cta-note">30-minute call · No pitch deck</span>
    </div>
  </div>
</section>
