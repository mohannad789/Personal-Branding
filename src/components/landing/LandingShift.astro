---
import { landing } from "../../content/landing";
const s = landing.shift;
const img = landing.visuals.shift;
---

<section class="lp-band lp-band--dim" aria-labelledby="lp-shift-h">
  <div class="lp-container">
    <div class="lp-split lp-split--img-right">
      <div class="lp-split-body">
        <p class="lp-eyebrow">The shift</p>
        <h2 id="lp-shift-h" class="lp-section-title">{s.title}</h2>
        <div class="lp-prose lp-prose--wide lp-prose--sectioned">
          {s.paragraphs.map((p, i) => <p class:list={[i === 0 && "lp-prose-lead"]}>{p}</p>)}
        </div>
        <p class="lp-section-cta lp-section-cta--left">
          <a class="btn btn-primary" href={s.ctaHref}>{s.ctaLabel}</a>
        </p>
      </div>
      <figure class="lp-split-media">
        <div class="lp-photo-frame">
          <img
            src={img}
            alt=""
            width="640"
            height="800"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="lp-photo-caption">Placeholder — workspace or city context.</figcaption>
      </figure>
    </div>
  </div>
</section>
