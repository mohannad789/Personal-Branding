---
import { landing } from "../../content/landing";
const c = landing.close;
---

<section class="lp-close lp-band lp-band--hero" aria-labelledby="lp-close-h">
  <div class="lp-close-inner">
    <h2 id="lp-close-h" class="lp-close-headline">{c.headlineEn}</h2>
    <div class="lp-close-ctas">
      <a class="btn btn-primary lp-close-btn" href={c.ctaHref}>{c.ctaEn}</a>
      <p class="lp-close-de">
        <a href={c.ctaHref} class="lp-close-de-link" lang="de">{c.ctaDe}</a>
      </p>
    </div>
  </div>
</section>
