---
import { showcase } from "../../content/showcase";
---

<section
  class="sc sc-metrics showcase-reveal"
  id="showcase-metrics"
  aria-labelledby="sc-metrics-h"
>
  <div class="sc-inner">
    <p class="eyebrow">Template · Metrics strip</p>
    <h2 id="sc-metrics-h" class="sc-title">{showcase.metrics.title}</h2>
    <p class="sc-lead">{showcase.metrics.lead}</p>
    <div class="sc-metrics-grid">
      {
        showcase.metrics.stats.map((s) => (
          <article class="sc-metric-card">
            <div class="sc-metric-top">
              <span
                class="sc-metric-value"
                data-countup
                data-target={String(s.target)}
                data-suffix={s.suffix ?? ""}
              >
                0{s.suffix}
              </span>
            </div>
            <p class="sc-metric-label">{s.label}</p>
            <p class="sc-metric-hint">{s.hint}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
