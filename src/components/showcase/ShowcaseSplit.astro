---
import { showcase } from "../../content/showcase";
---

<section
  class="sc sc-split section-alt showcase-reveal"
  id="showcase-split"
  aria-labelledby="sc-split-h"
>
  <div class="sc-inner sc-split-inner">
    <div class="sc-split-copy">
      <p class="eyebrow">Template · Split + product frame</p>
      <h2 id="sc-split-h" class="sc-title">{showcase.split.title}</h2>
      <p class="sc-lead">{showcase.split.lead}</p>
      <ul class="sc-checklist">
        {showcase.split.bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>
    <div class="sc-split-aside">
      <div class="sc-browser sc-browser--float" aria-hidden="true">
        <div class="sc-browser-chrome">
          <span class="sc-browser-dot"></span>
          <span class="sc-browser-dot"></span>
          <span class="sc-browser-dot"></span>
          <span class="sc-browser-url">{showcase.split.asideLabel}</span>
        </div>
        <div class="sc-browser-body">
          <p class="sc-browser-title">{showcase.split.asideTitle}</p>
          {showcase.split.asideLines.map((line) => (
            <div class="sc-browser-row">
              <span class="sc-browser-pill" />
              <span class="sc-browser-line" />
            </div>
          ))}
          <div class="sc-browser-chart">
            <div class="sc-browser-bar" style="width: 72%" />
            <div class="sc-browser-bar" style="width: 54%" />
            <div class="sc-browser-bar" style="width: 88%" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
