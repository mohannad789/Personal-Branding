---
import { showcase } from "../../content/showcase";
const { bento } = showcase;
---

<section
  class="sc sc-bento section-alt showcase-reveal"
  id="showcase-bento"
  aria-labelledby="sc-bento-h"
>
  <div class="sc-inner">
    <p class="eyebrow">Template · Bento grid</p>
    <h2 id="sc-bento-h" class="sc-title">{bento.title}</h2>
    <p class="sc-lead">{bento.lead}</p>

    <div class="sc-bento-grid">
      <a href={bento.hero.href} class="sc-bento-cell sc-bento-hero sc-bento-mesh">
        <span class="sc-bento-kicker">{bento.hero.kicker}</span>
        <h3 class="sc-bento-cell-title">{bento.hero.title}</h3>
        <p class="sc-bento-cell-text">{bento.hero.text}</p>
        <span class="sc-bento-link">{bento.hero.link}</span>
      </a>

      <div class="sc-bento-cell sc-bento-tall">
        <h3 class="sc-bento-cell-title">{bento.tall.title}</h3>
        <ul class="sc-bento-list">
          {bento.tall.bullets.map((b) => (
            <li>{b}</li>
          ))}
        </ul>
      </div>

      <div class="sc-bento-cell sc-bento-stat">
        <span class="sc-bento-stat-value">{bento.stat.value}</span>
        <span class="sc-bento-stat-label">{bento.stat.label}</span>
        <span class="sc-bento-stat-hint">{bento.stat.hint}</span>
      </div>

      <div class="sc-bento-cell sc-bento-mini">
        <h3 class="sc-bento-cell-title">{bento.mini.title}</h3>
        <p class="sc-bento-cell-text">{bento.mini.text}</p>
      </div>

      <div class="sc-bento-cell sc-bento-cta">
        <h3 class="sc-bento-cell-title">{bento.cta.title}</h3>
        <p class="sc-bento-cell-text">{bento.cta.text}</p>
        <a class="btn btn-primary sc-bento-btn" href={bento.cta.href}>
          {bento.cta.btn}
        </a>
      </div>
    </div>
  </div>
</section>
