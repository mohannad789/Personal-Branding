---
/** SaaS-style funnel ribbon — SVG + CSS (no Lottie). */
const gid = "funnel-grad";
---

<div class="motion-svg-wrap motion-svg-wrap--funnel" aria-hidden="true">
  <svg viewBox="0 0 640 120" class="funnel-svg" role="img">
    <title>Funnel-style flow diagram (decorative)</title>
    <defs>
      <linearGradient id={gid} x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#6d28d9" />
        <stop offset="48%" stop-color="#2563eb" />
        <stop offset="100%" stop-color="#14b8a6" />
      </linearGradient>
    </defs>
    <path
      class="funnel-path"
      fill={`url(#${gid})`}
      d="M 0 28
         C 120 28, 200 42, 320 52
         C 440 62, 520 68, 638 76
         L 640 88
         C 520 82, 440 78, 320 72
         C 200 66, 120 58, 0 52
         Z"
    />
    <path
      class="funnel-glow"
      fill="none"
      stroke-width="1.2"
      d="M 8 40 C 140 38, 220 50, 320 58 C 420 66, 520 72, 632 78"
    />
  </svg>
  <div class="funnel-labels">
    <span>1,979</span>
    <span>273</span>
    <span>5</span>
  </div>
</div>
