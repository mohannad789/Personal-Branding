---
/** Three-stage conversion ribbon — aligned segments + pills (no Lottie). */
---

<div class="motion-svg-wrap motion-svg-wrap--funnel" aria-hidden="true">
  <svg viewBox="0 0 560 92" class="funnel-svg funnel-svg--ribbon" role="img">
    <title>Three-stage funnel ribbon (decorative)</title>
    <path
      class="funnel-seg funnel-seg--1"
      d="M 10 18 L 198 20 L 184 64 L 10 66 Z"
      fill="#6d28d9"
    />
    <path
      class="funnel-seg funnel-seg--2"
      d="M 198 20 L 348 26 L 334 58 L 184 64 Z"
      fill="#2563eb"
    />
    <path
      class="funnel-seg funnel-seg--3"
      d="M 348 26 L 548 31 L 548 55 L 334 58 Z"
      fill="#0d9488"
    />
    <path class="funnel-divider" d="M 198 20 L 184 64" />
    <path class="funnel-divider" d="M 348 26 L 334 58" />

    <g class="funnel-pill" transform="translate(62, 36)">
      <rect class="funnel-pill-bg" x="-44" y="-14" width="88" height="28" rx="14" />
      <text class="funnel-pill-text" text-anchor="middle" x="0" y="5">1,979 · 100%</text>
    </g>
    <g class="funnel-pill" transform="translate(266, 38)">
      <rect class="funnel-pill-bg" x="-40" y="-14" width="80" height="28" rx="14" />
      <text class="funnel-pill-text" text-anchor="middle" x="0" y="5">273 · 14%</text>
    </g>
    <g class="funnel-pill" transform="translate(448, 40)">
      <rect class="funnel-pill-bg" x="-34" y="-14" width="68" height="28" rx="14" />
      <text class="funnel-pill-text" text-anchor="middle" x="0" y="5">5 · 0.3%</text>
    </g>
  </svg>
</div>
